{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ApiEnvelope",
  "type": "object",
  "properties": {
    "success": { "type": "boolean" },
    "data": {},
    "error": {
      "type": ["object", "null"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "details": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["code", "message"]
    },
    "traceId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "required": ["success", "traceId", "timestamp"]
}
